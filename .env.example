# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=local
LOG_LEVEL=INFO
LOG_JSON=false          

# ── OpenAI ────────────────────────────────────────────────────────────────────

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# ── LangSmith (optional) ──────────────────────────────────────────────────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=hybrid-ai-whatsapp-runtime
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ── Decision thresholds ────────────────────────────────────────────────────────
DECISION_CONFIDENCE_THRESHOLD=0.75
HUMAN_ESCALATION_THRESHOLD=0.60

# ── RAG / Retrieval ────────────────────────────────────────────────────────────
# onnx   → local ONNX MiniLM model, no API key required (default)
# openai → OpenAI text-embedding-3-small
RAG_EMBEDDING_PROVIDER=onnx
