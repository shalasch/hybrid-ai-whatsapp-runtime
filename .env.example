# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=local
LOG_LEVEL=INFO
LOG_JSON=false          # set true for structured JSON logs in production

# ── OpenAI (not required for local mock mode) ─────────────────────────────
OPENAI_API_KEY=

# ── LangSmith (optional — set LANGSMITH_TRACING=true to enable) ──────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=schillings-ai-runtime-local
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ── Decision thresholds ────────────────────────────────────────────────────
DECISION_CONFIDENCE_THRESHOLD=0.72
HUMAN_ESCALATION_THRESHOLD=0.50
